pipeline {
    agent any
    options {
        skipStagesAfterUnstable()
    }
    stages {
        stage('Build') {
            steps {
                echo "mvn clean install"
            }
        }
        stage('Test'){
            steps {
                echo "mvn test"
            }
        }
        stage('Report') {
            steps {
               echo "mvn verify"
            }
        }
    }
}
